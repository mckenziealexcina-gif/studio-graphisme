# === Canva Connect API — credentials de TON intégration ===
# Crée l'intégration sur https://www.canva.com/developers/  (voir canva/README.md)
# Puis copie ce fichier en  canva/.env  et colle tes valeurs ci-dessous.
# NE COMMITE JAMAIS .env (il est déjà dans .gitignore).

CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# Doit être EXACTEMENT la même URL que celle enregistrée dans ton intégration Canva.
CANVA_REDIRECT_URI=http://127.0.0.1:3001/callback
